<h1>Productos</h1>

<div class="products-container">
  {{#each products}}
  <div class="product-card">
    <h3>{{this.title}}</h3>
    <p>${{this.price}}</p>
    <p>Categoria: {{this.category}}</p>
    <button class="add-to-cart" data-id="{{this._id}}">Agregar al carrito</button>
    <a href="/products/{{this._id}}" class="details-link">Ver detalles</a>
  </div>
  {{/each}}
</div>

<div class="pagination">
  {{#if hasPrevPage}}
  <a href="{{prevLink}}" class="btn-page">Anterior</a>
  {{/if}}
  <span>Página {{page}} / {{totalPages}}</span>
  {{#if hasNextPage}}
  <a href="{{nextLink}}" class="btn-page">Siguiente</a>
  {{/if}}
</div>