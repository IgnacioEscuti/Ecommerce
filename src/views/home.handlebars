<h1>Productos</h1>

<div class="products-container">
    {{#each products}}
    <div class="product-card">
        <h3>{{this.title}}</h3>
        <p>${{this.price}}</p>

        <button class="add-to-cart" data-id="{{this._id}}">
            Agregar al carrito
        </button>
    </div>
    {{/each}}
</div>