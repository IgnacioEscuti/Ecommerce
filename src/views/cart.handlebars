<h1>Mi Carrito</h1>

{{#if cart.products.length}}
<table>
    <thead>
        <tr>
            <th>Producto</th>
            <th>Precio</th>
            <th>Cantidad</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        {{#each cart.products}}
        <tr>
            <td>{{this.product.title}}</td>
            <td>${{this.product.price}}</td>
            <td>{{this.quantity}}</td>
            <td>${{multiply this.product.price this.quantity}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>
{{else}}
<p>El carrito está vacío</p>
{{/if}}